#. Plugin Name of the plugin
msgid "WP Term Loop"
msgstr "Цикл терминов"

#. Description of the plugin
msgid "A Query Loop for taxonomy terms. Iterate terms with inner blocks, show posts per term, and bind term data to any block."
msgstr "Цикл запроса для терминов таксономий. Перебирает термины с вложенными блоками, показывает записи по каждому термину и привязывает данные термина к любому блоку."

#: wp-term-loop.php:27
msgid "Term Data"
msgstr "Данные термина"

#: blocks/loop/block.json
msgctxt "block title"
msgid "Term Loop"
msgstr "Цикл терминов"

#: blocks/loop/block.json
msgctxt "block description"
msgid "Iterates taxonomy terms and renders inner blocks for each term."
msgstr "Перебирает термины таксономии и выводит вложенные блоки для каждого термина."

#: blocks/term-template/block.json
msgctxt "block title"
msgid "Term Template"
msgstr "Шаблон термина"

#: blocks/term-template/block.json
msgctxt "block description"
msgid "Iterates posts within the current term. Place inside a Term Loop block."
msgstr "Перебирает записи текущего термина. Размещается внутри блока «Цикл терминов»."

